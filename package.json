{
  "name": "car-finder-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install && cd ../electron && npm install",
    "dev:backend": "cd backend && npm start",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "cd electron && npm start",
    "dev": "concurrently -n backend,frontend \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "cd electron && npm run build",
    "build": "npm run build:frontend && npm run build:electron"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
